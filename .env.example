# Google Tag Manager — required for analytics to load. GA4 (G-WEBEM9Z3BP)
# is configured INSIDE the GTM container, so only ONE network request hits
# *.googletagmanager.com per page (the GTM container itself).
NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-5WXR93CR

# GA4 Measurement ID — kept for client-side helpers that need to know
# analytics is enabled. Optional once GTM is in place.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-WEBEM9Z3BP

# Supabase (MMG project — content reads). Populate from Vercel project env.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MR_PROPS_CLIENT_ID=

# Postmark — newsletter / transactional. Populate from Vercel.
POSTMARK_SERVER_TOKEN=
NEWSLETTER_CONFIRM_SECRET=
POSTMARK_WEBHOOK_USER=
POSTMARK_WEBHOOK_PASS=
