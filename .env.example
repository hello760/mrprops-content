# Google Analytics 4 — required for analytics to load.
# Public env var: ships to the browser at build time.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-WEBEM9Z3BP

# Supabase (MMG project — content reads). Populate from Vercel project env.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MR_PROPS_CLIENT_ID=

# Postmark — newsletter / transactional. Populate from Vercel.
POSTMARK_SERVER_TOKEN=
NEWSLETTER_CONFIRM_SECRET=
POSTMARK_WEBHOOK_USER=
POSTMARK_WEBHOOK_PASS=
